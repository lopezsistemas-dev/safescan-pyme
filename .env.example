# ============================================================
# SafeScan PYME — Variables de entorno
# Copia este archivo a .env y ajusta los valores.
# Sin claves reales, el sistema funciona completo en modo mock.
# ============================================================

# --- IA conversacional (Gemini) ---
# Si está vacío, se usa el agente mock (respuestas guiadas locales).
GEMINI_API_KEY=
# Modelo de Gemini a utilizar cuando hay clave real.
GEMINI_MODEL=gemini-2.0-flash

# --- Inteligencia de amenazas (VirusTotal / Google Threat Intelligence) ---
# Si está vacío, se usa el proveedor mock (veredictos simulados realistas).
VIRUSTOTAL_API_KEY=
# Private Scanning requiere licencia Premium y acuerdo autorizado.
# En el MVP se simula: el conector está preparado pero no inventa endpoints.
VIRUSTOTAL_PRIVATE_SCANNING_ENABLED=false

# --- Modo de análisis ---
# true  = todos los análisis usan proveedores mock (recomendado para demo)
# false = usa claves reales si existen (Gemini / VirusTotal)
MOCK_SECURITY_ANALYSIS=true

# --- Base de datos (SQLite local) ---
DATABASE_URL="file:./dev.db"

# --- Cuarentena y almacenamiento ---
UPLOAD_DIR="./storage/quarantine"
# Horas de retención de archivos en cuarentena antes de su limpieza.
RETENTION_HOURS=24
# Tamaño máximo de subida en MB.
MAX_UPLOAD_MB=25
# Extensiones aceptadas para análisis (los ejecutables se aceptan para
# poder analizarlos, pero se marcan automáticamente como alto riesgo).
ALLOWED_FILE_TYPES=pdf,doc,docx,docm,xls,xlsx,xlsm,ppt,pptx,zip,rar,7z,txt,csv,html,htm,eml,rtf,odt,ods,jpg,jpeg,png,exe,msi,bat,cmd,js,vbs,scr,com,jar
